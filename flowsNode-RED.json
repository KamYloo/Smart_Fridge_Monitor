    {
        "id": "491ca5f39d8352b3",
        "type": "function",
        "z": "918af7635afbfa0f",
        "name": "Deszyfrator",
        "func": "let klucz = \"INZYNIER2024\";\nlet szyfrogram = msg.payload.toString(); \nlet odszyfrowane = \"\";\n\nfor (let i = 0; i < szyfrogram.length; i += 2) {\n    let bajt = parseInt(szyfrogram.substr(i, 2), 16);\n    let znakKlucza = klucz.charCodeAt((i/2) % klucz.length);\n    odszyfrowane += String.fromCharCode(bajt ^ znakKlucza);\n}\n\ntry {\n    msg.payload = JSON.parse(odszyfrowane);\n} catch(e) {\n    node.error(\"Błąd deszyfrowania: \" + szyfrogram);\n    return null; \n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 650,
        "y": 660,
        "wires": [
