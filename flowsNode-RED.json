    {
        "id": "format-chart-hist",
        "type": "function",
        "z": "918af7635afbfa0f",
        "name": "Formatowanie danych wykresu",
        "func": "var data = [{\n    \"series\": [\"Temperatura\"],\n    \"data\": [ [] ],\n    \"labels\": [\"Temperatura\"]\n}];\n\nif (Array.isArray(msg.payload)) {\n    msg.payload.forEach(function(row) {\n        let czasIso = row.czas.replace(' ', 'T');\n        data[0].data[0].push({\n            x: new Date(czasIso).getTime(),\n            y: row.temperatura\n        });\n    });\n}\n\nmsg.payload = data;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1310,
